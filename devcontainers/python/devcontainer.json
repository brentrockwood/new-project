{
  "name": "Python",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  // STACK drives postCreate.sh tool selection. No secrets here.
  "containerEnv": {
    "STACK": "python"
  },

  // DevPod will clone this repo and make it available in the container.
  // install.sh runs via postCreateCommand below to ensure symlinks are created
  // after the container filesystem is fully ready.
  "dotfilesRepository": "https://github.com/brentrockwood/dotfiles",
  "dotfilesInstallCommand": "echo 'postCreate will install dotfiles'",

  "postCreateCommand": "bash .devcontainer/postCreate.sh",

  // Forward ports as needed — add project-specific ports here.
  "forwardPorts": [],

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "ms-python.mypy-type-checker",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/root/.local/bin/uv"
      }
    }
  }
}
