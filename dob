#!/usr/bin/env bash
# dob — DOA Framework Bootstrap.
#
# Evaluates a target directory and adopts it into the DOA Framework,
# regardless of whether it is brand-new, an existing unadopted project,
# or already fully adopted.
#
# Usage:
#   dob <path> [--dry-run] [--force] [--remote]
#
# Options:
#   <path>       Target directory. Created if it does not exist.
#   --dry-run    Evaluate and print migration plan. No files written.
#   --force      Bypass hard fails after per-fail confirmation prompt.
#   --remote     Use dh1 SSH DevPod provider instead of local Docker.
#
# Prerequisites (must be in PATH):
#   bash 4+, gh, git, devpod
#
# Configuration (set in environment or ~/.zshrc.local):
#   NEW_PROJECT_GITHUB_USER   GitHub username (default: brentrockwood)
#   NEW_PROJECT_TEMPLATE      Template repo (default: github.com/brentrockwood/prjTemplate)
#   NEW_PROJECT_SRC_DIR       Where new projects land (default: ~/src)
#   DOB_DOA_REPO              DOA repo slug (default: brentrockwood/doa)

set -euo pipefail

DOB_VERSION="0.2.0"

# ── Script location (for finding scripts/security_scan.sh) ───────────────────
# Resolve script directory portably — readlink -f is GNU-only and absent on macOS.
if command -v greadlink &>/dev/null; then
  SCRIPT_DIR="$(cd "$(dirname "$(greadlink -f "${BASH_SOURCE[0]}")")" && pwd)"
elif command -v realpath &>/dev/null; then
  SCRIPT_DIR="$(cd "$(dirname "$(realpath "${BASH_SOURCE[0]}")")" && pwd)"
else
  # Portable symlink-following loop; works on Linux and macOS with no extra tools.
  _dob_src="${BASH_SOURCE[0]}"
  while [[ -L "$_dob_src" ]]; do
    _dob_dir="$(cd -P "$(dirname "$_dob_src")" && pwd)"
    _dob_src="$(readlink "$_dob_src")"
    [[ "$_dob_src" != /* ]] && _dob_src="$_dob_dir/$_dob_src"
  done
  SCRIPT_DIR="$(cd -P "$(dirname "$_dob_src")" && pwd)"
  unset _dob_src _dob_dir
fi

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
BOLD='\033[1m'
NC='\033[0m'

# ── Configuration (overridable via environment) ───────────────────────────────
GITHUB_USER="${NEW_PROJECT_GITHUB_USER:-brentrockwood}"
TEMPLATE_REPO="${NEW_PROJECT_TEMPLATE:-github.com/brentrockwood/prjTemplate}"
DOA_REPO_SLUG="${DOB_DOA_REPO:-brentrockwood/doa}"

# ── Global state ──────────────────────────────────────────────────────────────
TARGET=""
DRY_RUN=false
FORCE=false
USE_REMOTE=false
DOB_TMPDIR=""
DETECTED_STACK=""

# ── Check result arrays (Bash 4+ required) ────────────────────────────────────
declare -A CHECK_STATUS       # pass | warn | fail
declare -A CHECK_MESSAGE      # human-readable description of finding
declare -A CHECK_REMEDIATION  # what user must do (fail only, else empty string)
declare -A CHECK_ACTION       # function name to call in migrate (auto only, else empty)
declare -A CHECK_ORDER        # integer, determines report display order

# ── Migration plan: array of "funcname|description" entries ──────────────────
MIGRATION_PLAN=()

# ── Cleanup ───────────────────────────────────────────────────────────────────
cleanup() {
  if [[ -n "$DOB_TMPDIR" && -d "$DOB_TMPDIR" ]]; then
    rm -rf "$DOB_TMPDIR"
  fi
}
trap cleanup EXIT

# ── Helpers ───────────────────────────────────────────────────────────────────
die()      { echo -e "\n${RED}✗ $*${NC}\n" >&2; exit 1; }
step_log() { echo "  → $*"; }

ensure_doa_cloned() {
  [[ -d "${DOB_TMPDIR:-}/doa" ]] && return
  [[ -z "$DOB_TMPDIR" ]] && DOB_TMPDIR=$(mktemp -d)
  local url="https://github.com/$DOA_REPO_SLUG.git"
  if gh auth status &>/dev/null 2>&1; then
    gh repo clone "$DOA_REPO_SLUG" "$DOB_TMPDIR/doa" -- --quiet 2>/dev/null \
      || git clone --quiet "$url" "$DOB_TMPDIR/doa"
  else
    git clone --quiet "$url" "$DOB_TMPDIR/doa"
  fi
}

# ── Check functions ───────────────────────────────────────────────────────────

check_uncommitted() {
  CHECK_ORDER[uncommitted]=1
  CHECK_ACTION[uncommitted]=""
  if [[ ! -d "$TARGET/.git" ]]; then
    CHECK_STATUS[uncommitted]="pass"
    CHECK_MESSAGE[uncommitted]="working tree clean (no git repo yet)"
    CHECK_REMEDIATION[uncommitted]=""
    return
  fi
  local dirty
  dirty=$(git -C "$TARGET" status --porcelain 2>/dev/null)
  if [[ -z "$dirty" ]]; then
    CHECK_STATUS[uncommitted]="pass"
    CHECK_MESSAGE[uncommitted]="working tree clean"
    CHECK_REMEDIATION[uncommitted]=""
  else
    CHECK_STATUS[uncommitted]="fail"
    CHECK_MESSAGE[uncommitted]="uncommitted files in working tree"
    CHECK_REMEDIATION[uncommitted]="git add -A && git commit -m '...'  or  git stash"
  fi
}

check_partial_adoption() {
  CHECK_ORDER[partial_adoption]=2
  CHECK_ACTION[partial_adoption]=""
  local marker="$TARGET/project/doa.md"
  local -a sentinels=(
    "$TARGET/project/context.md"
    "$TARGET/project/scripts/add-context"
    "$TARGET/project/scripts/read-context"
    "$TARGET/project/scripts/rotate-context"
  )

  if [[ -f "$marker" ]]; then
    CHECK_STATUS[partial_adoption]="pass"
    CHECK_MESSAGE[partial_adoption]="fully adopted"
    CHECK_REMEDIATION[partial_adoption]=""
    return
  fi

  local -a found=()
  for s in "${sentinels[@]}"; do
    [[ -f "$s" ]] && found+=("${s#"$TARGET"/}")
  done

  if [[ ${#found[@]} -eq 0 ]]; then
    CHECK_STATUS[partial_adoption]="pass"
    CHECK_MESSAGE[partial_adoption]="no partial adoption detected"
    CHECK_REMEDIATION[partial_adoption]=""
  else
    CHECK_STATUS[partial_adoption]="fail"
    CHECK_MESSAGE[partial_adoption]="partial DOA adoption detected"
    local found_list
    found_list=$(printf '  %s\n' "${found[@]}")
    CHECK_REMEDIATION[partial_adoption]="sentinel files found:
$found_list
complete adoption manually or remove them before running dob"
  fi
}

check_security() {
  CHECK_ORDER[security]=3
  CHECK_ACTION[security]=""

  if [[ ! -d "$TARGET" ]]; then
    CHECK_STATUS[security]="pass"
    CHECK_MESSAGE[security]="security scan skipped (target does not exist yet)"
    CHECK_REMEDIATION[security]=""
    return
  fi

  local scan_script="$SCRIPT_DIR/scripts/security_scan.sh"

  if [[ ! -f "$scan_script" ]]; then
    CHECK_STATUS[security]="warn"
    CHECK_MESSAGE[security]="security scan unavailable (scripts/security_scan.sh not found)"
    CHECK_REMEDIATION[security]=""
    return
  fi

  local rc=0
  (cd "$TARGET" && bash "$scan_script") > /dev/null 2>&1 || rc=$?

  case $rc in
    0)
      CHECK_STATUS[security]="pass"
      CHECK_MESSAGE[security]="security scan clean"
      CHECK_REMEDIATION[security]=""
      ;;
    1)
      CHECK_STATUS[security]="fail"
      CHECK_MESSAGE[security]="secrets detected in repo"
      CHECK_REMEDIATION[security]="run scripts/security_scan.sh and resolve all findings"
      ;;
    *)
      CHECK_STATUS[security]="warn"
      CHECK_MESSAGE[security]="security scan could not complete (script error)"
      CHECK_REMEDIATION[security]=""
      ;;
  esac
}

check_gh_auth() {
  CHECK_ORDER[gh_auth]=4
  CHECK_ACTION[gh_auth]=""
  if gh auth status &>/dev/null 2>&1; then
    CHECK_STATUS[gh_auth]="pass"
    CHECK_MESSAGE[gh_auth]="gh authenticated"
    CHECK_REMEDIATION[gh_auth]=""
  else
    CHECK_STATUS[gh_auth]="warn"
    CHECK_MESSAGE[gh_auth]="gh not authenticated"
    CHECK_REMEDIATION[gh_auth]=""
  fi
}

check_stack() {
  CHECK_ORDER[stack]=5
  CHECK_ACTION[stack]=""
  local detected=""
  [[ -f "$TARGET/package.json" ]]                                           && detected="typescript"
  [[ -f "$TARGET/pyproject.toml" || -f "$TARGET/requirements.txt" ]]       && detected="python"
  [[ -f "$TARGET/go.mod" ]]                                                 && detected="go"

  if [[ -n "$detected" ]]; then
    DETECTED_STACK="$detected"
    CHECK_STATUS[stack]="pass"
    CHECK_MESSAGE[stack]="stack: $detected"
    CHECK_REMEDIATION[stack]=""
  else
    DETECTED_STACK=""
    CHECK_STATUS[stack]="warn"
    CHECK_MESSAGE[stack]="stack unknown"
    CHECK_REMEDIATION[stack]=""
  fi
}

# ── Evaluate ──────────────────────────────────────────────────────────────────
evaluate() {
  check_uncommitted
  check_partial_adoption
  check_security
  check_gh_auth
  check_stack
}

# ── Migration Plan ────────────────────────────────────────────────────────────
build_migration_plan() {
  MIGRATION_PLAN=()
  local files_will_be_written=false

  # 10: create project/ dir
  if [[ ! -d "$TARGET/project" ]]; then
    MIGRATION_PLAN+=("step_create_project_dir|create project/ directory")
    files_will_be_written=true
  fi

  # 20: copy scripts (missing or incomplete)
  local scripts_complete=true
  for s in add-context read-context rotate-context; do
    [[ ! -f "$TARGET/project/scripts/$s" ]] && scripts_complete=false && break
  done
  if [[ "$scripts_complete" == false ]]; then
    MIGRATION_PLAN+=("step_copy_scripts|copy project/scripts/ from DOA repo")
    files_will_be_written=true
  fi

  # 30: write doa.md
  if [[ ! -f "$TARGET/project/doa.md" ]]; then
    MIGRATION_PLAN+=("step_write_doa|write project/doa.md")
    files_will_be_written=true
  fi

  # 40: write project.md
  if [[ ! -f "$TARGET/project/project.md" ]]; then
    MIGRATION_PLAN+=("step_write_project_md|write project/project.md")
    files_will_be_written=true
  fi

  # 50: init git
  if [[ ! -d "$TARGET/.git" ]]; then
    MIGRATION_PLAN+=("step_init_git|initialise git repository")
    files_will_be_written=true
  fi

  # 60: write .gitignore
  if [[ ! -f "$TARGET/.gitignore" ]]; then
    MIGRATION_PLAN+=("step_write_gitignore|write .gitignore")
    files_will_be_written=true
  fi

  # 70: write secrets.env.example
  if [[ ! -f "$TARGET/secrets.env.example" ]]; then
    MIGRATION_PLAN+=("step_write_secrets_example|write secrets.env.example")
    files_will_be_written=true
  fi

  # Only continue if there's something to do
  if [[ "$files_will_be_written" == false ]]; then
    return
  fi

  # 80: context entry (always when migrating)
  MIGRATION_PLAN+=("step_add_context_entry|write first context entry")

  # 90: initial commit
  MIGRATION_PLAN+=("step_initial_commit|initial commit")

  # Determine whether a GitHub remote already exists
  local has_remote=false
  if [[ -d "$TARGET/.git" ]]; then
    git -C "$TARGET" remote get-url origin &>/dev/null 2>&1 && has_remote=true
  fi

  if [[ "$has_remote" == true ]]; then
    # 95: push DOA changes to a feature branch on the existing remote
    MIGRATION_PLAN+=("step_push_doa_branch|push dob/initial-adoption branch to origin")
    # 120: open PR against existing remote
    MIGRATION_PLAN+=("step_open_pr|open pull request")
  else
    # 100: create new GitHub repo
    MIGRATION_PLAN+=("step_create_github_repo|create GitHub repository")
    # 110: create devpod (new projects only)
    MIGRATION_PLAN+=("step_create_devpod|create DevPod workspace")
    # 120: open PR
    MIGRATION_PLAN+=("step_open_pr|open pull request")
  fi
}

# ── Print Report ──────────────────────────────────────────────────────────────
print_report() {
  echo ""
  echo "dob v${DOB_VERSION} — evaluating ${TARGET}"
  echo ""

  local -a check_order=(uncommitted partial_adoption security gh_auth stack)
  for check in "${check_order[@]}"; do
    local status="${CHECK_STATUS[$check]}"
    local msg="${CHECK_MESSAGE[$check]}"
    local rem="${CHECK_REMEDIATION[$check]}"
    case "$status" in
      pass) printf "  ✓  %s\n" "$msg" ;;
      warn) printf "  ⚠  %-48s [WARN]\n" "$msg" ;;
      fail)
        printf "  ✗  %-48s [FAIL]\n" "$msg"
        if [[ -n "$rem" ]]; then
          while IFS= read -r line; do
            printf "     → %s\n" "$line"
          done <<< "$rem"
        fi
        ;;
    esac
  done

  echo ""

  if [[ ${#MIGRATION_PLAN[@]} -eq 0 ]]; then
    echo "nothing to do. project is fully adopted."
    return
  fi

  local step_count=${#MIGRATION_PLAN[@]}
  echo "migration plan ($step_count step$([ "$step_count" -ne 1 ] && echo s)):"
  local i=1
  for entry in "${MIGRATION_PLAN[@]}"; do
    printf "  %d. %s\n" "$i" "${entry#*|}"
    ((i++))
  done

  # Count hard fails
  local fail_count=0
  for check in "${check_order[@]}"; do
    [[ "${CHECK_STATUS[$check]}" == "fail" ]] && ((fail_count++))
  done

  if [[ $fail_count -gt 0 ]]; then
    echo ""
    if [[ $fail_count -eq 1 ]]; then
      echo "1 failure. resolve before migrating, or run with --force."
    else
      echo "${fail_count} failures. resolve before migrating, or run with --force."
    fi
  fi
}

# ── Force Confirmation ────────────────────────────────────────────────────────
confirm_force() {
  local response
  for check in uncommitted partial_adoption security; do
    [[ "${CHECK_STATUS[$check]}" != "fail" ]] && continue
    echo ""
    case "$check" in
      uncommitted)
        echo "WARNING: Uncommitted files detected. If migration fails or corrupts your"
        echo "working tree, there is no recovery path. You will lose unsaved work."
        ;;
      partial_adoption)
        echo "WARNING: Partial DOA adoption detected. Proceeding may overwrite or conflict"
        echo "with existing framework files. Review what's present before continuing."
        ;;
      security)
        echo "WARNING: Secrets or sensitive data detected in this repository. Proceeding"
        echo "will commit DOA framework files alongside potentially exposed credentials."
        ;;
    esac
    printf "Proceed anyway? (y/n) "
    read -r response
    if [[ ! "$response" =~ ^[Yy]$ ]]; then
      echo "Aborted."
      exit 1
    fi
  done
}

# ── Step Functions ────────────────────────────────────────────────────────────

step_create_project_dir() {
  step_log "creating project/ directory"
  mkdir -p "$TARGET/project"
}

step_copy_scripts() {
  step_log "copying project/scripts/ from DOA repo"
  ensure_doa_cloned
  mkdir -p "$TARGET/project/scripts"
  cp -r "$DOB_TMPDIR/doa/project/scripts/." "$TARGET/project/scripts/"
  chmod +x "$TARGET/project/scripts/"*
}

step_write_doa() {
  step_log "writing project/doa.md"
  ensure_doa_cloned
  cp "$DOB_TMPDIR/doa/project/doa.md" "$TARGET/project/doa.md"
}

step_write_project_md() {
  step_log "writing project/project.md"
  local project_name
  project_name=$(basename "$TARGET")

  # Detect existing code: anything beyond .git, .gitignore, secrets.env.example, project/
  local has_existing_code=false
  while IFS= read -r -d '' entry; do
    local rel="${entry#"$TARGET"/}"
    case "$rel" in
      .git|.gitignore|secrets.env.example|project) ;;
      *) has_existing_code=true; break ;;
    esac
  done < <(find "$TARGET" -mindepth 1 -maxdepth 1 -print0 2>/dev/null)

  if [[ "$has_existing_code" == true ]]; then
    local detected_files
    detected_files=$(ls "$TARGET" 2>/dev/null | grep -v '^\.git$' | paste -sd ' ' || true)
    cat > "$TARGET/project/project.md" << EOF
# ${project_name}

## Discovered State

<!-- Populated by dob. Do not edit manually. -->
- **Stack**: ${DETECTED_STACK:-unknown}
- **Detected files**: ${detected_files}

## Ratified Decisions

<!-- To be filled in during first planning session with agent. -->

## Open Questions

<!-- Ambiguities surfaced during onboarding. -->

## Known Debt / Deferred Items

<!-- Findings from dob evaluate that need attention but are not blocking. -->
EOF
  else
    cat > "$TARGET/project/project.md" << EOF
# ${project_name}

## Overview

<!-- Describe this project. -->

## Stack

<!-- Language, frameworks, key dependencies. -->

## Architecture

<!-- High-level structure. -->

## Implementation Plan

<!-- Ordered phases and tasks. -->
EOF
  fi
}

step_init_git() {
  step_log "initialising git repository"
  git -C "$TARGET" init --quiet
  git -C "$TARGET" symbolic-ref HEAD refs/heads/main
}

step_write_gitignore() {
  step_log "writing .gitignore"
  cat > "$TARGET/.gitignore" << 'EOF'
# Secrets — never commit these
secrets.env
*.pem
*.key

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo
EOF

  case "${DETECTED_STACK:-}" in
    python)
      cat >> "$TARGET/.gitignore" << 'EOF'

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
.uv/
EOF
      ;;
    typescript)
      cat >> "$TARGET/.gitignore" << 'EOF'

# Node / TypeScript
node_modules/
dist/
.next/
.nuxt/
*.tsbuildinfo
EOF
      ;;
    go)
      cat >> "$TARGET/.gitignore" << 'EOF'

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
/vendor/
EOF
      ;;
  esac
}

step_write_secrets_example() {
  step_log "writing secrets.env.example"
  cat > "$TARGET/secrets.env.example" << 'EOF'
# secrets.env.example — Template for secrets.env (which is gitignored).
#
# Copy this file to secrets.env and fill in real values.
# NEVER commit secrets.env.
#
# Usage in shell:
#   source secrets.env
#
# Usage in scripts:
#   set -a; source secrets.env; set +a

# API_KEY=your_api_key_here
# DATABASE_URL=postgres://user:password@localhost/dbname
EOF
}

step_add_context_entry() {
  step_log "writing first context entry"
  local scripts_dir="$TARGET/project/scripts"
  chmod +x \
    "$scripts_dir/add-context" \
    "$scripts_dir/read-context" \
    "$scripts_dir/rotate-context" 2>/dev/null || true
  "$scripts_dir/add-context" \
    --agent "dob" \
    --model "v${DOB_VERSION}" \
    --output "$TARGET/project/context.md" \
    "DOB migration complete. Project bootstrapped by dob v${DOB_VERSION}. Branch: main"
}

step_initial_commit() {
  step_log "creating initial commit"
  git -C "$TARGET" add -A
  if git -C "$TARGET" diff --cached --quiet 2>/dev/null; then
    step_log "(nothing to commit, skipping)"
    return 0
  fi
  git -C "$TARGET" commit -m "DOB: Initial DOA framework scaffold"
}

step_push_doa_branch() {
  step_log "pushing dob/initial-adoption branch to origin"
  git -C "$TARGET" checkout -b dob/initial-adoption
  git -C "$TARGET" push -u origin dob/initial-adoption
}

step_create_github_repo() {
  step_log "creating GitHub repository"
  local project_name
  project_name=$(basename "$TARGET")
  local github_repo="$GITHUB_USER/$project_name"

  gh repo create "$github_repo" \
    --private \
    --description "$project_name" \
    --source "$TARGET" \
    --remote origin \
    --push=false

  git -C "$TARGET" remote set-url origin "git@github.com:${github_repo}.git"
  git -C "$TARGET" push -u origin main

  git -C "$TARGET" checkout -b initial-scaffold
  git -C "$TARGET" push -u origin initial-scaffold
}

step_create_devpod() {
  step_log "creating DevPod workspace"
  local project_name
  project_name=$(basename "$TARGET")
  local -a devpod_args
  if [[ "$USE_REMOTE" == true ]]; then
    devpod_args=("--provider" "ssh" "--provider-option" "HOST=dh1")
  else
    devpod_args=("--provider" "docker")
  fi
  devpod up "$TARGET" --id "$project_name" "${devpod_args[@]}" --ide none
}

step_open_pr() {
  step_log "opening pull request"
  local project_name
  project_name=$(basename "$TARGET")
  local github_repo="$GITHUB_USER/$project_name"
  local head_branch
  head_branch=$(git -C "$TARGET" rev-parse --abbrev-ref HEAD)

  local ahead_count
  ahead_count=$(git -C "$TARGET" rev-list --count "main..$head_branch" 2>/dev/null || echo 0)
  if [[ "$ahead_count" -eq 0 ]]; then
    step_log "(no commits ahead of main on $head_branch; skipping PR creation)"
    return 0
  fi

  local pr_url
  pr_url=$(gh pr create \
    --repo "$github_repo" \
    --base main \
    --head "$head_branch" \
    --title "DOB: Adopt ${project_name} into the DOA Framework" \
    --body "Initial DOA framework scaffold.

- Created by: \`dob v${DOB_VERSION}\`
- Stack: \`${DETECTED_STACK:-unknown}\`

Generated by \`dob\`." \
    2>&1)

  echo "  PR: $pr_url"
}

# ── Migrate ───────────────────────────────────────────────────────────────────
migrate() {
  echo ""
  echo -e "${BLUE}${BOLD}Migrating...${NC}"
  echo ""
  for entry in "${MIGRATION_PLAN[@]}"; do
    local func="${entry%%|*}"
    "$func" || die "Migration failed at step: ${entry#*|}"
  done
  echo ""
  echo -e "${GREEN}${BOLD}Migration complete.${NC}"
}

# ── Usage ─────────────────────────────────────────────────────────────────────
print_usage() {
  cat << EOF
dob v${DOB_VERSION} — DOA Framework Bootstrap

Evaluates a target directory and adopts it into the DOA Framework,
regardless of whether it is brand-new, an existing unadopted project,
or already fully adopted.

Usage:
  dob <path> [--dry-run] [--force] [--remote]

Options:
  <path>       Target directory. Created if it does not exist.
  --dry-run    Evaluate and print migration plan. No files written.
  --force      Bypass hard fails after per-fail confirmation prompt.
  --remote     Use dh1 SSH DevPod provider instead of local Docker.

Prerequisites (must be in PATH):
  bash 4+, gh, git, devpod

Configuration (set in environment or ~/.zshrc.local):
  NEW_PROJECT_GITHUB_USER   GitHub username (default: brentrockwood)
  NEW_PROJECT_TEMPLATE      Template repo (default: github.com/brentrockwood/prjTemplate)
  NEW_PROJECT_SRC_DIR       Where new projects land (default: ~/src)
  DOB_DOA_REPO              DOA repo slug (default: brentrockwood/doa)
EOF
}

# ── Prerequisites ─────────────────────────────────────────────────────────────
check_prerequisites() {
  local bash_major="${BASH_VERSINFO[0]}"
  [[ "$bash_major" -ge 4 ]] \
    || die "Bash 4+ required (found Bash ${BASH_VERSION}). On macOS: brew install bash"
  for tool in gh git devpod; do
    command -v "$tool" &>/dev/null \
      || die "$tool not found in PATH. Please install it before continuing."
  done
}

# ── parse_args ────────────────────────────────────────────────────────────────
parse_args() {
  if [[ $# -eq 0 ]]; then
    print_usage >&2
    exit 1
  fi

  for arg in "$@"; do
    case "$arg" in
      --dry-run) DRY_RUN=true ;;
      --force)   FORCE=true ;;
      --remote)  USE_REMOTE=true ;;
      --help|-h)
        print_usage
        exit 0
        ;;
      -*)
        echo "Unknown option: $arg" >&2
        exit 1
        ;;
      *)
        if [[ -n "$TARGET" ]]; then
          echo "Unexpected argument: $arg" >&2
          exit 1
        fi
        TARGET="$arg"
        ;;
    esac
  done

  if [[ -z "$TARGET" ]]; then
    echo "Error: path is required." >&2
    exit 1
  fi

  # Resolve to absolute path (target may not exist yet)
  case "$TARGET" in
    /*) ;;
    *)  TARGET="$(pwd)/$TARGET" ;;
  esac

  # Normalize path only if the directory already exists; defer creation to migrate.
  if [[ -d "$TARGET" ]]; then
    TARGET="$(cd "$TARGET" && pwd)"
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────
main() {
  parse_args "$@"
  check_prerequisites
  evaluate
  build_migration_plan
  print_report

  [[ "$DRY_RUN" == true ]] && exit 0
  [[ ${#MIGRATION_PLAN[@]} -eq 0 ]] && exit 0

  # Count hard fails
  local fail_count=0
  for check in uncommitted partial_adoption security; do
    [[ "${CHECK_STATUS[$check]}" == "fail" ]] && ((fail_count++))
  done

  if [[ $fail_count -gt 0 ]]; then
    [[ "$FORCE" == false ]] && exit 1
    confirm_force
  fi

  migrate
}

main "$@"
