# dob Secrets Template
# ==================================
# Copy this file to secrets.env and fill in your actual values.
# secrets.env is gitignored — never commit it.
#
# This file documents every available configuration option.
# Values here are safe placeholder examples only.

# ==============================================================================
# AI PROVIDER (if applicable)
# ==============================================================================
# Options: openai, anthropic, ollama, gemini
AI_PROVIDER=anthropic

# OpenAI
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=mistral

# Gemini
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash


# ==============================================================================
# [SERVICE] CREDENTIALS (example — replace with your service)
# ==============================================================================
# SERVICE_API_KEY=your-key-here
# SERVICE_TOKEN_FILE=token.json
# SERVICE_CREDENTIALS_FILE=credentials.json


# ==============================================================================
# PROCESSING
# ==============================================================================
# Note: DRY_RUN and LOG_LEVEL are non-secret defaults defined in .env.example.
# Override them here only if you need a secret-level value to take precedence.
# Values in secrets.env take precedence over .env.example when both are loaded.
BATCH_SIZE=20


# ==============================================================================
# DATABASE / STATE (if applicable)
# ==============================================================================
# DATABASE_PATH=state.db
