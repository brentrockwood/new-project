#!/usr/bin/env bash
# Convenience script for local development runs.
# Adjust the command below to match your project's entry point.

set -euo pipefail

if [[ ! -d .venv ]]; then
  echo "Error: .venv not found. Run: python -m venv .venv && pip install -r requirements.txt" >&2
  exit 1
fi

source .venv/bin/activate
python main.py run
